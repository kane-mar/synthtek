# ── Local Development ──────────────────────────────────────────────────────
# API keys for LLM providers (optional for development)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=

# ── CI/CD GitHub Secrets (set in GitHub repo settings) ────────────────────
# These are required by the production deploy step in .github/workflows/ci.yml
#
# PRODUCTION_HOST         — IP or hostname of your production server
# PRODUCTION_PORT         — SSH port (default 22)
# PRODUCTION_USER         — SSH username
# PRODUCTION_PASSWORD     — SSH password (or use PRODUCTION_SSH_KEY instead)
# PRODUCTION_SSH_KEY      — SSH private key for key-based auth
# PRODUCTION_PORT_MAPPING — Docker port mapping, e.g. "8080:8080"
