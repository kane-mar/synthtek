{
  "name": "synthtek",
  "version": "1.0.0",
  "description": "A modular plugin-based AI agent framework",
  "main": "dist/src/cli.js",
  "type": "module",
  "bin": {
    "synthtek": "dist/src/cli.js"
  },
  "scripts": {
    "build": "tsc && cp src/webui/frontend.html dist/src/webui/frontend.html",
    "start": "node dist/src/cli.js",
    "dev": "node --enable-source-maps src/cli.ts",
    "test": "npm run build && node --test --test-concurrency=4 dist/tests/**/*.test.js",
    "test:coverage": "npm run build && node --test --experimental-test-coverage --test-concurrency=4 dist/tests/**/*.test.js",
    "test:playwright": "npm run build && node --test --test-concurrency=1 dist/tests/webui/webui-e2e-playwright.e2e.js dist/tests/e2e/*.e2e.js",
    "test:e2e": "playwright test",
    "test:e2e:docker": "scripts/e2e-docker.sh",
    "lint": "biome check src/ tests/",
    "lint:fix": "biome check --write src/ tests/",
    "clean": "rm -rf dist",
    "prepare": "husky || true",
    "prebuild": "find dist -type f -delete 2>/dev/null; true"
  },
  "keywords": [
    "cli",
    "agent",
    "automation",
    "synthtek",
    "plugin",
    "ai"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "commander": "^12.0.0",
    "discord.js": "^14.26.3",
    "glob": "^10.3.10",
    "telegraf": "^4.16.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@playwright/test": "^1.60.0",
    "@types/node": "^20.10.0",
    "husky": "^9.1.7",
    "playwright": "1.60.0",
    "puppeteer": "^25.1.0",
    "typescript": "^5.9.3"
  }
}
