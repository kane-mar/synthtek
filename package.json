{
  "name": "synthtek",
  "version": "1.0.0",
  "description": "A modular plugin-based AI agent framework",
  "main": "dist/src/cli.js",
  "type": "module",
  "bin": {
    "synthtek": "dist/src/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/src/cli.js",
    "dev": "node --enable-source-maps src/cli.ts",
    "test": "npm run build && node --test dist/tests/**/*.test.js",
    "test:coverage": "node --test --experimental-test-coverage tests/**/*.test.ts",
    "lint": "eslint src/",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "cli",
    "agent",
    "automation",
    "synthtek",
    "plugin",
    "ai"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "commander": "^12.0.0",
    "discord.js": "^14.26.3",
    "dotenv": "^16.3.1",
    "glob": "^10.3.10",
    "minimatch": "^9.0.3"
  },
  "devDependencies": {
    "@types/glob": "^8.1.0",
    "@types/minimatch": "^5.1.2",
    "@types/node": "^20.10.0",
    "typescript": "^5.3.0"
  }
}
